# Set to true to send events via @plausible-analytics/tracker
NEXT_PUBLIC_PLAUSIBLE_ENABLED=true

# Domain configured in your Plausible dashboard, e.g. parablebloom.com
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=parable-bloom.pages.dev

# Optional: override Plausible API host for self-hosted setups
NEXT_PUBLIC_PLAUSIBLE_ENDPOINT=https://stats.garciaericn.com/api/event
