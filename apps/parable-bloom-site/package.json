{
  "name": "parable-bloom-site",
  "version": "0.1.0",
  "scripts": {
    "build": "next build",
    "dev": "next dev --port 4201",
    "format": "prettier --write .",
    "format:ci": "prettier --check .",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --cache --fix",
    "lint:report": "eslint . --cache -o ./eslintReport.html -f html",
    "prepare": "husky",
    "start": "next start --port 4201",
    "validate": "node ./scripts/validate.mjs"
  },
  "dependencies": {
    "@gv-tech/ui-web": "2.17.0",
    "@plausible-analytics/tracker": "^0.4.4",
    "@tailwindcss/postcss": "^4.2.1",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@eng618/prettier-config": "^2.10.0",
    "@gv-tech/eslint-config": "^0.1.14",
    "@next/eslint-plugin-next": "^16.1.6",
    "@types/node": "24.7.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "^10.0.3",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "private": true,
  "lint-staged": {
    "*.(js|ts|mjs|cjs)?(x)": [
      "prettier --write",
      "eslint --cache --fix"
    ],
    "*.(md)?(x)": [
      "prettier --write"
    ]
  },
  "prettier": "@eng618/prettier-config"
}
