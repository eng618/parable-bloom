# Fastfile for iOS - Parable Bloom
# Documentation: https://docs.fastlane.tools/

require 'json'
require 'fileutils'

default_platform(:ios)

platform :ios do
  # Private helper to setup certificates and provisioning profiles
  private_lane :_setup_signing do
    setup_ci if ENV['CI']

    import_certificate(
      certificate_path: ENV["IOS_CERTIFICATE_PATH"] || "/tmp/distribution-cert.p12",
      certificate_password: ENV["IOS_CERTIFICATE_PASSWORD"],
      keychain_name: ENV["KEYCHAIN_NAME"] || "ci.keychain",
      keychain_password: ENV["KEYCHAIN_PASSWORD"] || "ci_password"
    )

    install_provisioning_profile(path: ENV["IOS_PROVISIONING_PROFILE_PATH"] || "/tmp/profile.mobileprovision")
  end

  # Private helper to build IPA
  private_lane :_build_ipa do
    _setup_signing

    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          "com.garciaericn.parablebloom" => ENV["IOS_PROVISIONING_PROFILE_SPECIFIER"] || "Parable Bloom App Store"
        }
      },
      output_directory: "../build/ios/ipa"
    )
  end

  # Private helper to setup App Store Connect API authentication
  private_lane :_setup_app_store_connect_auth do
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_KEY"],
      is_key_content_base64: true
    )
  end

  desc "Push a new build to TestFlight"
  lane :beta do
    _setup_app_store_connect_auth
    _build_ipa

    # Increment build number for next build
    increment_build_number(
      build_number: latest_testflight_build_number + 1,
      xcodeproj: "Runner.xcodeproj"
    )

    # Upload to TestFlight (uses authenticated session from _setup_app_store_connect_auth)
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      skip_submission: true,
      distribute_external: false
    )

    UI.success("✅ Successfully uploaded to TestFlight")
  end

  desc "Deploy to App Store"
  lane :release do
    _setup_app_store_connect_auth
    _build_ipa

    # Upload to App Store (uses authenticated session from _setup_app_store_connect_auth)
    upload_to_app_store(
      skip_metadata: true,
      skip_screenshots: true,
      force: true,
      submit_for_review: false
    )

    UI.success("✅ Successfully uploaded to App Store")
  end

  desc "Capture local App Store screenshots using Flutter integration tests"
  lane :screenshots do
    project_root = File.expand_path('../..', __dir__)
    driver = 'test_driver/integration_test.dart'
    target = 'integration_test/app_screenshots_test.dart'
    source_dir = File.join(project_root, 'build', 'integration_test_screenshots')
    destination_dir = File.expand_path('./screenshots/en-US', __dir__)

    FileUtils.mkdir_p(destination_dir)
    FileUtils.rm_f(Dir[File.join(destination_dir, '*.png')])

    raw_devices = sh("cd #{project_root} && flutter devices --machine")
    parsed_devices = JSON.parse(raw_devices)
    ios_devices = parsed_devices.select do |d|
      d['targetPlatform'].to_s.start_with?('ios')
    end

    device_ids = (ENV['IOS_SCREENSHOT_DEVICE_IDS'] || '')
      .split(',')
      .map(&:strip)
      .reject(&:empty?)

    if device_ids.empty?
      iphone = ios_devices.find { |d| d['name'].to_s.include?('iPhone') }
      ipad = ios_devices.find { |d| d['name'].to_s.include?('iPad') }
      device_ids = [iphone, ipad].compact.map { |d| d['id'] }
    end

    if device_ids.empty?
      available = parsed_devices.map { |d| "#{d['name']} (#{d['id']}, #{d['targetPlatform']})" }
      UI.user_error!(
        "No iOS simulator found. Launch at least one iPhone/iPad simulator and re-run. Visible devices: #{available.join(', ')}"
      )
    end

    device_name_by_id = ios_devices.each_with_object({}) { |d, map| map[d['id']] = d['name'] }

    device_ids.each do |device_id|
      device_name = device_name_by_id[device_id] || device_id
      slug = device_name.downcase.gsub(/[^a-z0-9]+/, '_').gsub(/^_|_$/, '')

      UI.message("📱 Capturing screenshots on #{device_name} (#{device_id})")
      FileUtils.rm_f(Dir[File.join(source_dir, '*.png')])

      sh("cd #{project_root} && flutter drive --driver=#{driver} --target=#{target} --dart-define=SCREENSHOT_MODE=true -d #{device_id}")

      screenshots = Dir[File.join(source_dir, '*.png')].sort
      UI.user_error!("No screenshots generated in #{source_dir} for #{device_name}") if screenshots.empty?

      screenshots.each do |file|
        FileUtils.cp(file, File.join(destination_dir, "#{slug}_#{File.basename(file)}"))
      end
    end

    if ENV['IOS_SCREENSHOT_FRAMEIT'] == 'true'
      sh("cd #{__dir__} && frameit")
    end

    UI.success("✅ Local screenshots captured to #{destination_dir}")
  end

  desc "Upload only screenshots to App Store Connect"
  lane :upload_screenshots do
    _setup_app_store_connect_auth

    upload_to_app_store(
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: false,
      force: true,
      submit_for_review: false
    )

    UI.success("✅ Screenshots uploaded to App Store Connect")
  end

  desc "Build IPA without uploading"
  lane :build_release do
    _build_ipa

    UI.success("✅ IPA built successfully")
    UI.message("📦 IPA location: ../build/ios/ipa/Runner.ipa")
  end

  desc "Validate credentials and configuration"
  lane :validate do
    # Validate App Store Connect API Key
    _setup_app_store_connect_auth

    UI.success("✅ App Store Connect API key validated")

    # Check if certificate exists
    if ENV["IOS_CERTIFICATE_PATH"] && File.exist?(ENV["IOS_CERTIFICATE_PATH"])
      UI.success("✅ Distribution certificate found")
    else
      UI.error("❌ Distribution certificate not found at #{ENV['IOS_CERTIFICATE_PATH']}")
    end

    # Check if provisioning profile exists
    if ENV["IOS_PROVISIONING_PROFILE_PATH"] && File.exist?(ENV["IOS_PROVISIONING_PROFILE_PATH"])
      UI.success("✅ Provisioning profile found")
    else
      UI.error("❌ Provisioning profile not found at #{ENV['IOS_PROVISIONING_PROFILE_PATH']}")
    end
  end

  desc "Setup keychain for CI"
  lane :setup_keychain do
    create_keychain(
      name: ENV["KEYCHAIN_NAME"] || "ci.keychain",
      password: ENV["KEYCHAIN_PASSWORD"] || "ci_password",
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      add_to_search_list: true
    )

    UI.success("✅ Keychain created and configured")
  end

  desc "Clean up CI artifacts"
  lane :cleanup do
    if ENV['CI']
      delete_keychain(name: ENV["KEYCHAIN_NAME"] || "ci.keychain") if File.exist?(File.expand_path("~/Library/Keychains/ci.keychain-db"))
      UI.success("✅ Cleaned up CI artifacts")
    end
  end
end
