rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Development environment - game progress data
    match /game_progress_dev/{userId} {
      // Users can read/write their own progress data
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Allow access to the modules subcollection
      match /modules/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Preview environment - game progress data
    match /game_progress_preview/{userId} {
      // Users can read/write their own progress data
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Allow access to the modules subcollection
      match /modules/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Production environment - game progress data
    match /game_progress_prod/{userId} {
      // Users can read/write their own progress data
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Allow access to the modules subcollection
      match /modules/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Users collection for future use (if needed for user profiles, etc.)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Dynamic levels collection
    match /levels_dev/{levelId} {
      allow read: if true;
      allow write: if false;
    }

    match /levels_preview/{levelId} {
      allow read: if true;
      allow write: if false;
    }

    match /levels_prod/{levelId} {
      allow read: if true;
      allow write: if false;
    }

    // Dynamic config rules for OTA updates
    match /configs_dev/{configId} {
      allow read: if true;
      allow write: if false;
    }

    match /configs_preview/{configId} {
      allow read: if true;
      allow write: if false;
    }

    match /configs_prod/{configId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
