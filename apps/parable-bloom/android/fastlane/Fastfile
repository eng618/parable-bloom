# Fastfile for Android - Parable Bloom
# Documentation: https://docs.fastlane.tools/

opt_out_usage

require 'fileutils'
require 'json'
require 'shellwords'

default_platform(:android)

platform :android do
  # Private helper lane to build release bundle
  private_lane :_build_release_bundle do
    keystore_path = ENV["ANDROID_KEYSTORE_PATH"] || "/tmp/parable-bloom.jks"
    gradle(
      task: "bundle",
      build_type: "Release",
      properties: {
        "android.injected.signing.store.file" => keystore_path,
        "android.injected.signing.store.password" => ENV["ANDROID_STORE_PASSWORD"],
        "android.injected.signing.key.alias" => ENV["ANDROID_KEY_ALIAS"],
        "android.injected.signing.key.password" => ENV["ANDROID_KEY_PASSWORD"],
      }
    )
  end

  desc "Get the latest version code from a specific Google Play track"
  lane :get_latest_version_code do |options|
    track = options[:track] || "internal"
    version_codes = google_play_track_version_codes(
      package_name: "com.garciaericn.parable_bloom",
      track: track,
      json_key: ENV["GOOGLE_PLAY_SERVICE_ACCOUNT_PATH"] || '/tmp/service-account.json'
    )
    latest = version_codes.max || 0
    puts "LATEST_VERSION_CODE=#{latest}"
  end

  desc "Deploy a new version to the Google Play Console (Internal Testing)"
  lane :deploy do
    # The release bundle is expected to be built + signed by Flutter
    # (e.g. `flutter build appbundle --release --build-number ...`) before calling this lane.

    # Upload to Play Console (internal track for testing)
    # Authentication via Appfile (json_key or json_key_data)
    upload_to_play_store(
      json_key: ENV["GOOGLE_PLAY_SERVICE_ACCOUNT_PATH"] || '/tmp/service-account.json',
      track: 'internal',
      aab: '../build/app/outputs/bundle/release/app-release.aab',
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      release_status: ENV["GOOGLE_PLAY_RELEASE_STATUS"] || 'draft',
      ack_bundle_installation_warning: true,
      changes_not_sent_for_review: true,
      timeout: 600
    )

    UI.success("✅ Successfully deployed to Google Play Console (Internal Testing)")
  end

  desc "Deploy to Google Play Console Beta Track"
  lane :beta do
    # The release bundle is expected to be built + signed by Flutter
    # (e.g. `flutter build appbundle --release --build-number ...`) before calling this lane.

    # Authentication via Appfile (json_key or json_key_data)
    upload_to_play_store(
      json_key: ENV["GOOGLE_PLAY_SERVICE_ACCOUNT_PATH"] || '/tmp/service-account.json',
      track: 'beta',
      aab: '../build/app/outputs/bundle/release/app-release.aab',
      skip_upload_metadata: false,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      release_status: ENV["GOOGLE_PLAY_RELEASE_STATUS"] || 'draft'
    )

    UI.success("✅ Successfully deployed to Beta track")
  end

  desc "Promote Internal to Beta"
  lane :promote_to_beta do
    # Authentication via Appfile (json_key or json_key_data)
    upload_to_play_store(
      json_key: ENV["GOOGLE_PLAY_SERVICE_ACCOUNT_PATH"] || '/tmp/service-account.json',
      track: 'internal',
      track_promote_to: 'beta',
      skip_upload_aab: true,
      skip_upload_metadata: true,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      release_status: ENV["GOOGLE_PLAY_RELEASE_STATUS"] || 'draft'
    )

    UI.success("✅ Successfully promoted to Beta")
  end

  desc "Deploy to Production"
  lane :production do
    # The release bundle is expected to be built + signed by Flutter
    # (e.g. `flutter build appbundle --release --build-number ...`) before calling this lane.

    # Authentication via Appfile (json_key or json_key_data)
    upload_to_play_store(
      json_key: ENV["GOOGLE_PLAY_SERVICE_ACCOUNT_PATH"] || '/tmp/service-account.json',
      track: 'production',
      aab: '../build/app/outputs/bundle/release/app-release.aab',
      skip_upload_metadata: false,
      skip_upload_images: true,
      skip_upload_screenshots: true,
      release_status: ENV["GOOGLE_PLAY_RELEASE_STATUS"] || 'draft'
    )

    UI.success("✅ Successfully deployed to Production!")
  end

  desc "Build release bundle only (no upload)"
  lane :build_release do
    build_number = ENV["BUILD_NUMBER"] || "1"
    build_name = ENV["BUILD_NAME"]

    cmd = "flutter build appbundle --release --build-number #{build_number}"
    cmd += " --build-name #{build_name}" if build_name && !build_name.empty?

    sh("cd .. && #{cmd}")

    UI.success("✅ Release bundle built successfully")
    UI.message("📦 Bundle location: ../build/app/outputs/bundle/release/app-release.aab")
  end

  desc "Validate bundle before upload"
  lane :validate do
    _build_release_bundle

    # Validate credentials via Appfile
    # (Appfile will ensure json_key or json_key_data is properly configured)
    UI.success("✅ Bundle and credentials validated successfully")
  end

  desc "Generate Play Store screenshots via Flutter integration test"
  lane :screenshots do
    project_root = File.expand_path('../..', __dir__)
    driver = 'test_driver/integration_test.dart'
    target = 'integration_test/app_screenshots_test.dart'
    source_dir = File.join(project_root, 'build', 'integration_test_screenshots')
    destination_dir = File.expand_path('./screenshots/en-US', __dir__)

    FileUtils.mkdir_p(destination_dir)
    FileUtils.rm_f(Dir[File.join(destination_dir, '*.png')])

    device_ids = (ENV['ANDROID_SCREENSHOT_DEVICE_IDS'] || '')
      .split(',')
      .map(&:strip)
      .reject(&:empty?)

    if device_ids.empty?
      adb_output = sh('adb devices -l')
      device_ids = adb_output
        .lines
        .map(&:strip)
        .reject(&:empty?)
        .reject { |line| line.start_with?('List of devices attached') }
        .select { |line| line.include?(' device ') || line.end_with?(' device') }
        .map { |line| line.split.first }
    end

    if device_ids.empty?
      UI.user_error!(
        'No Android device/emulator found. Start an emulator and re-run. `adb devices -l` returned no connected Android devices.'
      )
    end

    ready_device_ids = device_ids.select do |device_id|
      escaped_device_id = Shellwords.escape(device_id)
      sh("adb -s #{escaped_device_id} wait-for-device")

      boot_completed = `adb -s #{escaped_device_id} shell getprop sys.boot_completed 2>/dev/null`.strip
      package_service = `adb -s #{escaped_device_id} shell service check package 2>&1`.strip
      activity_service = `adb -s #{escaped_device_id} shell service check activity 2>&1`.strip

      is_ready = boot_completed == '1' &&
        package_service.include?('found') &&
        activity_service.include?('found')

      unless is_ready
        UI.important(
          "Skipping Android device #{device_id}: boot_completed=#{boot_completed.inspect}, package=#{package_service.inspect}, activity=#{activity_service.inspect}"
        )
      end

      is_ready
    end

    if ready_device_ids.empty?
      UI.user_error!(
        'No ready Android device/emulator found. Connected devices exist, but Android package/activity services are unavailable. Restart the emulator and re-run.'
      )
    end

    ready_device_ids.each do |device_id|
      device_name = device_id
      slug = device_name.downcase.gsub(/[^a-z0-9]+/, '_').gsub(/^_|_$/, '')

      UI.message("📱 Capturing screenshots on #{device_name} (#{device_id})")
      FileUtils.rm_f(Dir[File.join(source_dir, '*.png')])

      sh(
        "cd #{project_root.shellescape} && flutter drive --driver=#{driver.shellescape} --target=#{target.shellescape} --dart-define=SCREENSHOT_MODE=true -d #{device_id.shellescape}"
      )

      screenshots = Dir[File.join(source_dir, '*.png')].sort
      UI.user_error!("No screenshots generated in #{source_dir} for #{device_name}") if screenshots.empty?

      screenshots.each do |file|
        FileUtils.cp(file, File.join(destination_dir, "#{slug}_#{File.basename(file)}"))
      end
    end

    UI.success("📸 Local screenshots copied to #{destination_dir}")
  end
end
